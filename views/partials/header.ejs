<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mateando 🧉</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="main-header">
    <a href="/" class="header-logo"><h1>Mateando🧉</h1></a>
    <% if (typeof ocultarExtras === 'undefined' || !ocultarExtras) { %>
        <div class="header-search">
            <input type="text" placeholder="Buscar Productos">
            <button type="submit">🔍</button>
        </div>
        <nav class="header-nav">
            <a href="/login" title="Iniciar Sesión"><i class="fa-solid fa-user"></i></a>
            <a href="/register" title="Registrarse"><i class="fa-solid fa-user-plus"></i></a>
            <a href="/cart" title="Carrito"><i class="fa-solid fa-cart-shopping"></i></a>
        </nav>
    <% } %>
</header>