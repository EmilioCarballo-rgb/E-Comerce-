<style>
    
    .cart-card { background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; box-shadow: 0px 4px 10px rgba(0,0,0,0.05); display: flex; flex-direction: column; height: 100%; }
    .cart-card-link { text-decoration: none; color: inherit; display: block; flex-grow: 1; }
    .cart-card-img { 
        width: 100%; 
        height: 250px; 
        object-fit: contain; 
        background-color: #ffffff; 
        padding: 15px; 
        box-sizing: border-box; 
    }
    .cart-card-body { padding: 20px; text-align: center; }
    .cart-card-title { font-size: 1.2rem; color: #333; margin: 0 0 10px 0; }
    .cart-card-price { font-size: 1.5rem; font-weight: bold; color: #e44d26; margin-bottom: 10px; }
    .cart-card-desc { font-size: 1rem; color: #666; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .cart-card-actions { padding: 0 20px 20px 20px; text-align: center; }
    
    /* Estilizamos el botón para que el formulario no afecte el diseño */
    .btn-add-card { background: #4a4e54; color: white; border: none; padding: 10px 20px; border-radius: 20px; cursor: pointer; text-decoration: none; font-size: 1rem; display: inline-block; transition: background 0.3s; width: 100%; box-sizing: border-box; }
    .btn-add-card:hover { background: #363d46; }
</style>

<article class="cart-card">
    <a href="/products/<%= product.id %>" class="cart-card-link">
        <img src="<%= product.image %>" alt="<%= product.title %>" class="cart-card-img">
        <div class="cart-card-body">
            <h3 class="cart-card-title"><%= product.title %></h3>
            <p class="cart-card-price">$<%= product.price %></p>
            <p class="cart-card-desc"><%= product.description %></p>
        </div>
    </a>
    <div class="cart-card-actions">
        <form action="/cart/add/<%= product.id %>" method="POST">
            <button type="submit" class="btn-add-card">Agregar al carrito 🛒</button>
        </form>
    </div>
</article>