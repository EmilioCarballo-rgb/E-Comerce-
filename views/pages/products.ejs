<%- include('../partials/header') %>

<main class="detalle-contenedor" style="max-width: 1200px; margin: 0 auto; padding: 20px;">

    <section style="display: flex; gap: 40px; margin-bottom: 50px;">
        <div class="detalle-imagen" style="flex: 1;">
            <img src="<%= products.image ? products.image : '/images/default-mate.jpg' %>" 
                 alt="<%= products.title %>" 
                 style="width: 100%; border-radius: 15px;">
        </div>

        <div class="detalle-info" style="flex: 1;">
            <h2 style="font-size: 2.5rem; margin-bottom: 10px;">
                <%= products.title %>
            </h2>
            <h3 class="detalle-precio" style="color: #27ae60; font-size: 2rem; margin-bottom: 20px;">
                $<%= products.price %>
            </h3>

            <p style="font-size: 1.1rem; line-height: 1.6; color: #555; margin-bottom: 30px;">
                <%= products.description %>
            </p>

            <form action="/cart/add/<%= products.id %>" method="POST">
                <button type="submit" class="detalle-btn-carrito" style="padding: 15px 30px; cursor: pointer;">
                    Agregar al carrito 🛒
                </button>
            </form>
        </div>
    </section>

    <section class="productos-relacionados" style="border-top: 1px solid #eee; padding-top: 40px;">
        <h2 style="text-align: center; margin-bottom: 30px;">También te puede interesar...</h2>

        <% if (relacionados && relacionados.length > 0) { %>
            <div class="product-grid" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px;">
                <% relacionados.forEach(relacionado => { %>
                    <%- include('../partials/productCard', { product: relacionado }) %>
                <% }) %>
            </div>
        <% } else { %>
            <div style="text-align: center; color: #888; padding: 20px;">
                <p>No hay más productos similares en la categoría <%= products.category %> por el momento.</p>
            </div>
        <% } %>
    </section>

</main>

<%- include('../partials/footer') %>