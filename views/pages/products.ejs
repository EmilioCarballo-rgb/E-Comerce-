<%- include('../partials/header') %>

<main class="product-detail-container">
    <!-- Sección de Imagen y Descripción -->
    <section class="product-header">
        <img src="<%= products.image %>" alt="<%= products.title %>" class="detail-img">
        
        <div class="detail-info">
            <h1><%= products.title %></h1>
            <p class="detail-category">Categoría: <%= products.category %></p>
            <p class="detail-price">$<%= products.price %></p>
            
            <!-- MODIFICACIÓN CLAVE: Formulario POST para el detalle -->
            <form action="/cart/add/<%= products.id %>" method="POST">
                <button type="submit" class="btn-principal">
                    Añadir al carrito 🧉
                </button>
            </form>
            
            <p class="detail-description"><%= products.description %></p>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>