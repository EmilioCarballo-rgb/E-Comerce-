<div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; padding: 20px;">

    <% for (const product of products) { %>
        <a href="/products/<%=product.id %>" style="text-decoration: none; color: inherit; display: block; width: 300px;">
            <article style="background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; box-shadow: 0px 4px 10px rgba(0,0,0,0.05); height: 100%;">
                
                <img src="<%= product.image%>" alt="<%= product.title %>" style="width: 100%; height: 250px; object-fit: cover;">

                <div style="padding: 20px; text-align: center;">
                    <h3 style="font-size: 1.2rem; color: #333; margin: 0 0 10px 0;"><%= product.title %></h3>
                    <p style="font-size: 1.5rem; font-weight: bold; color: #e44d26; margin-bottom: 15px;"> <%= product.price %></p>
                    <p style="font-size: 1rem; color: #666; margin-bottom: 15px;"> <%= product.description %></p>
                
                    <button style="background: #4a4e54; color: white; border: none; padding: 8px 15px; border-radius: 20px; cursor: pointer; margin-bottom: 10px;">Quitar</button>

                    <div style="display: flex; justify-content: center; align-items: center; border: 1px solid #ccc; border-radius: 20px; padding: 5px 10px;">
                        <button style="background: none; border: none; cursor: pointer; font-weight: bold;"> - </button>
                        <span style="margin: 0 15px;">1</span> 
                        <button style="background: none; border: none; cursor: pointer; font-weight: bold;"> + </button>
                    </div>
                </div>
            </article>
        </a>
    <% } %>

</div>