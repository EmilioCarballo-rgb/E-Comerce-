<article style="background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; box-shadow: 0px 4px 10px rgba(0,0,0,0.05); padding-bottom: 15px; width: 100%; max-width: 300px; margin: 0 auto;">
    
    <a href="/products/<%=product.id %>" style="text-decoration: none; color: inherit; display: block;">
        <img src="<%= product.image%>" alt="<%= product.title %>" style="width: 100%; height: 250px; object-fit: cover;">
        
        <div style="padding: 15px; text-align: center;">
            <h3 style="font-size: 1.2rem; color: #333; margin: 0 0 10px 0;"><%= product.title %></h3>
            <p style="font-size: 1.5rem; font-weight: bold; color: #e44d26; margin-bottom: 5px;">$<%= product.price %></p>
            <p style="font-size: 1rem; color: #666; margin-bottom: 10px;"><%= product.description %></p>
        </div>
    </a>

    <div style="text-align: center;">
        <a href="/agregar-al-carrito/<%= product.id %>" style="background: #4a4e54; color: white; border: none; padding: 10px 20px; border-radius: 20px; cursor: pointer; text-decoration: none; font-size: 1rem; display: inline-block;">
            Agregar al carrito 🛒
        </a>
    </div>
</article>