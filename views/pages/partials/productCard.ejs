<a href="/products/<%=product.id %>" style="text-decoration: none; color: inherit; display: block;">
    <article style="background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; box-shadow: 0px 4px 10px rgba(0,0,0,0.05);">
    
        <img src="<%= product.image%>" alt="<%= product.title %>" style="width: 100%; height: 250px; object-fit: cover;">
    

        <div style="padding: 20px; text-align: center;">
        
            <h3 style="font-size: 1.2rem; color: #333; margin: 0 0 10px 0;"><%= product.title %></h3>
            <p style="font-size: 1.5rem; font-weight: bold; color: #e44d26; margin-bottom: 15px;"> <%= product.price %></p>
            <p style="font-size: 1.5rem; font-weight: bold; color: #e44d26; margin-bottom: 15px;"> <%= product.description %></p>
        

        
            <button style="width: 100%; padding: 10px; background-color: #363d46; color: white; border: none; border-radius: 5px; font-size: 1rem; cursor: pointer;">Agregar al carrito</button>
        </div>
    </article>
</a>