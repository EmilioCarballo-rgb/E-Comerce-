<%- include('../partials/header') %>

<main style="padding: 40px 5%; font-family: Arial, sans-serif; background-color: #f8f9fa; min-height: 80vh;">
    <div style="max-width: 1000px; margin: 0 auto; display: flex; gap: 40px; flex-wrap: wrap;">
        
        <div style="flex: 2; min-width: 300px; background-color: white; padding: 30px; border-radius: 12px; box-shadow: 0px 4px 15px rgba(0,0,0,0.05);">
            <h2 style="margin-top: 0; color: #333; border-bottom: 2px solid #eaeaea; padding-bottom: 10px;">Detalles de Facturación</h2>
            
            <form action="/checkout/procesar-pago" method="POST">
                
                <h3 style="font-size: 1.1rem; color: #555; margin-top: 20px;">1. Datos Personales</h3>
                <div style="display: flex; gap: 15px;">
                    <div style="flex: 1;">
                        <label style="font-size: 0.9rem; color: #666;">Nombre completo</label>
                        <!-- ATRIBUTO NAME AGREGADO -->
                        <input type="text" name="nombreCompleto" placeholder="Ej: Franco" required style="width: 100%; padding: 12px; margin-top: 5px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">
                    </div>
                    <div style="flex: 1;">
                        <label style="font-size: 0.9rem; color: #666;">Correo electrónico</label>
                        <input type="email" name="email" placeholder="correo@ejemplo.com" required style="width: 100%; padding: 12px; margin-top: 5px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">
                    </div>
                </div>

                <h3 style="font-size: 1.1rem; color: #555; margin-top: 10px;">2. Envío</h3>
                <label style="font-size: 0.9rem; color: #666;">Dirección de entrega</label>
                <input type="text" name="direccion" placeholder="Calle y número" required style="width: 100%; padding: 12px; margin-top: 5px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">

                <h3 style="font-size: 1.1rem; color: #555; margin-top: 10px;">3. Pago Seguro 🔒</h3>
                <label style="font-size: 0.9rem; color: #666;">Número de Tarjeta</label>
                <input type="text" name="numeroTarjeta" placeholder="0000 0000 0000 0000" required style="width: 100%; padding: 12px; margin-top: 5px; margin-bottom: 15px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">
                
                <div style="display: flex; gap: 15px;">
                    <div style="flex: 1;">
                        <label style="font-size: 0.9rem; color: #666;">Vencimiento</label>
                        <input type="text" name="vencimiento" placeholder="MM/AA" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">
                    </div>
                    <div style="flex: 1;">
                        <label style="font-size: 0.9rem; color: #666;">Cód. Seguridad (CVC)</label>
                        <input type="text" name="cvc" placeholder="123" required style="width: 100%; padding: 12px; margin-top: 5px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box;">
                    </div>
                </div>

                <button type="submit" style="width: 100%; padding: 15px; margin-top: 30px; background-color: #363d46; color: white; border: none; border-radius: 8px; font-size: 1.2rem; font-weight: bold; cursor: pointer; transition: 0.3s;">
                    Confirmar Pago
                </button>
            </form>
        </div>

        <div style="flex: 1; min-width: 250px; background-color: white; padding: 30px; border-radius: 12px; box-shadow: 0px 4px 15px rgba(0,0,0,0.05); height: fit-content;">
            <h3 style="margin-top: 0; color: #333; border-bottom: 2px solid #eaeaea; padding-bottom: 10px;">Resumen</h3>
            
            <div style="display: flex; justify-content: space-between; margin-bottom: 15px; color: #555;">
                <span>Subtotal</span>
                <strong>$ <%= total %></strong>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 15px; color: #555;">
                <span>Envío</span>
                <strong>Gratis</strong>
            </div>
            
            <div style="display: flex; justify-content: space-between; margin-top: 20px; padding-top: 20px; border-top: 2px solid #eaeaea; font-size: 1.3rem; color: #333;">
                <strong>Total</strong>
                <strong style="color: #e44d26;">$ <%= total %></strong>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>