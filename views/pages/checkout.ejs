<%- include('../partials/header') %>

    <main class="checkout-main">

        <div class="checkout-container">

            <div class="checkout-box checkout-form-col">
                <h2 class="checkout-title">Detalles de Facturación</h2>

                <form action="/procesar-pago" method="POST">

                    <h3 class="checkout-subtitle">1. Datos Personales</h3>
                    <div class="checkout-row">
                        <div class="checkout-col">
                            <label class="checkout-label">Nombre completo</label>
                            <input type="text" class="checkout-input" placeholder="Ej: Franco">
                        </div>
                        <div class="checkout-col">
                            <label class="checkout-label">Correo electrónico</label>
                            <input type="email" class="checkout-input" placeholder="correo@ejemplo.com">
                        </div>
                    </div>

                    <h3 class="checkout-subtitle" style="margin-top: 10px;">2. Envío</h3>
                    <label class="checkout-label">Dirección de entrega</label>
                    <input type="text" class="checkout-input" placeholder="Calle y número">

                    <h3 class="checkout-subtitle" style="margin-top: 10px;">3. Pago Seguro 🔒</h3>
                    <label class="checkout-label">Número de Tarjeta</label>
                    <input type="text" class="checkout-input" placeholder="0000 0000 0000 0000">

                    <div class="checkout-row">
                        <div class="checkout-col">
                            <label class="checkout-label">Vencimiento</label>
                            <input type="text" class="checkout-input" placeholder="MM/AA">
                        </div>
                        <div class="checkout-col">
                            <label class="checkout-label">Cód. Seguridad (CVC)</label>
                            <input type="text" class="checkout-input" placeholder="123">
                        </div>
                    </div>

                    <button type="submit" class="checkout-btn">
                        Confirmar Pago
                    </button>
                </form>
            </div>
            <div class="checkout-box checkout-summary-col">
                <h3 class="checkout-title">Resumen</h3>

                <div class="checkout-summary-item">
                    <span>Subtotal</span>
                    <strong>$ <%= total %></strong>
                </div>
                <div class="checkout-summary-item">
                    <span>Envío</span>
                    <strong>Gratis</strong>
                </div>

                <div class="checkout-summary-total">
                    <strong>Total</strong>
                    <strong class="checkout-total-price">$ <%= total %></strong>
                </div>
            </div>

        </div>
    </main>

    <%- include('../partials/footer') %>