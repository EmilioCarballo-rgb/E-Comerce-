<%- include('../partials/header') %>

<main class="register-main">
    <section class="register-card">
        <h2>¡REGISTRATE!</h2>
        <form action="/register" method="POST" class="register-form" id="registerForm">
            
            <div class="form-group">
                <label for="nombre" class="sr-only">Nombre</label>
                <input type="text" id="nombre" name="nombre" placeholder="Nombre">
                <span id="error-nombre" class="error-message"></span>
            </div>

            <div class="form-group">
                <label for="apellido" class="sr-only">Apellido</label>
                <input type="text" id="apellido" name="apellido" placeholder="Apellido">
                <span id="error-apellido" class="error-message"></span>
            </div>

            <div class="form-group">
                <label for="email" class="sr-only">Email</label>
                <input type="email" id="email" name="email" placeholder="Email">
                <span id="error-email" class="error-message"></span>
            </div>

            <div class="form-group">
                <label for="password" class="sr-only">Contraseña</label>
                <input type="password" id="password" name="password" placeholder="Contraseña">
                <span id="error-password" class="error-message"></span>
            </div>

            <div class="form-group">
                <label for="passwordConfirm" class="sr-only">Repita Contraseña</label>
                <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="Repita Contraseña">
                <span id="error-passwordConfirm" class="error-message"></span>
            </div>

            <button type="submit" class="btn-submit">Crear Cuenta</button>
        </form>

        <div class="login-link">
            <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
            <p><a href="/" class="btn-back">Volver al inicio</a></p>
        </div>
    </section>
</main>

<script>
    const form = document.getElementById('registerForm');
    const siteName = "mateando"; 

    form.addEventListener('submit', function(e) {
        let hasErrors = false;

        const fields = {
            nombre: document.getElementById('nombre'),
            apellido: document.getElementById('apellido'),
            email: document.getElementById('email'),
            password: document.getElementById('password'),
            confirm: document.getElementById('passwordConfirm')
        };

        const values = {
            nombre: fields.nombre.value.trim(),
            apellido: fields.apellido.value.trim(),
            email: fields.email.value.trim(),
            password: fields.password.value.trim(),
            confirm: fields.confirm.value.trim()
        };

        const showError = (field, message) => {
            const errorSpan = document.getElementById(`error-${field.id}`);
            errorSpan.textContent = message;
            errorSpan.style.display = 'block';
            field.classList.add('invalid');
            hasErrors = true;
        };

        document.querySelectorAll('.error-message').forEach(s => s.style.display = 'none');
        document.querySelectorAll('input').forEach(i => i.classList.remove('invalid'));

        // 1. Campos obligatorios
        if (!values.nombre) showError(fields.nombre, "El nombre es obligatorio.");
        if (!values.apellido) showError(fields.apellido, "El apellido es obligatorio.");
        
        // 2. Email válido
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(values.email)) showError(fields.email, "Email no válido.");

        // 3. Password (8 caracteres, letra, número, especial)
        const passRegex = /^(?=.*[a-zA-Z])(?=.*\d)(?=.*[!@#$%^&*(),.?":{}|<>]).{8,}$/;
        if (!passRegex.test(values.password)) {
            showError(fields.password, "Mínimo 8 caracteres, una letra, un número y un carácter especial.");
        }

        // 4. Cadenas prohibidas
        const forbidden = [
            "password", "1234", "qwerty", 
            siteName.toLowerCase(), values.nombre.toLowerCase(), values.apellido.toLowerCase()
        ];
        
        if (forbidden.some(word => word !== "" && values.password.toLowerCase().includes(word))) {
            showError(fields.password, "La contraseña es muy débil o contiene datos personales.");
        }

        // 5. Password != Email
        if (values.password === values.email && values.password !== "") {
            showError(fields.password, "La contraseña no puede ser igual al email.");
        }

        // 6. Confirmación de password
        if (values.password !== values.confirm) {
            showError(fields.confirm, "Las contraseñas no coinciden.");
        }

        if (hasErrors) {
            e.preventDefault();
        }
    });
</script>

<%- include('../partials/footer') %>