<%- include('../partials/header') %>

<style>
    /* Usa exactamente los mismos estilos que login.ejs (los pego resumidos para ahorrarte espacio, copiá el bloque <style> entero del login acá arriba) */
    body { background-color: #EAE3D2; margin: 0; }
    .register-main { display: flex; justify-content: center; align-items: center; min-height: 85vh; padding: 40px 20px; font-family: Arial, Helvetica, sans-serif; }
    .register-card { background-color: #83af31; padding: 40px; border-radius: 10px; box-shadow: -10px 20px 20px rgba(11, 80, 2, 0.973); width: 100%; max-width: 400px; text-align: center; }
    .register-card h2 { font-family: Georgia, serif; font-size: 32px; margin-bottom: 30px; color: #EAE3D2; }
    .register-form { display: flex; flex-direction: column; gap: 15px; }
    .form-group { text-align: left; }
    .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }
    .form-group input { width: 100%; padding: 12px 15px; border: 1px solid #ccc; border-radius: 5px; font-size: 16px; box-sizing: border-box; }
    .form-group input:focus { border-color: #09D092; outline: none; }
    .btn-submit { background-color: #ffffff; color: #333333; border: none; padding: 15px; border-radius: 5px; font-size: 16px; cursor: pointer; margin-top: 10px; }
    .btn-submit:hover { background-color: #e6e6e6b7; }
    .login-link { margin-top: 25px; font-size: 14px; color: #e2e2e2; }
    .login-link a { color: #147700; text-decoration: underline; }
    .btn-back { display: inline-block; background-color: #ffffff; color: #333333; padding: 10px 20px; border-radius: 5px; text-decoration: none !important; font-size: 16px; margin-top: 15px; border: 1px solid #cccccc; }

    @media (max-width: 480px) {
        .register-main { padding: 20px 15px; }
        .register-card { padding: 30px 20px; box-shadow: 0px 10px 15px rgba(11, 80, 2, 0.5); }
        .register-card h2 { font-size: 26px; margin-bottom: 20px; }
    }
</style>

<main class="register-main">
    <section class="register-card">
        <h2>¡REGISTRATE!</h2>
        <form action="/register" method="POST" class="register-form">
            <div class="form-group">
                <label for="email" class="sr-only">Email</label>
                <input type="email" id="email" name="email" placeholder="Email" required>
            </div>
            <div class="form-group">
                <label for="password" class="sr-only">Contraseña</label>
                <input type="password" id="password" name="password" placeholder="Contraseña" required>
            </div>
            <div class="form-group">
                <label for="passwordConfirm" class="sr-only">Repita Contraseña</label>
                <input type="password" id="passwordConfirm" name="passwordConfirm" placeholder="Repita Contraseña" required>
            </div>
            <button type="submit" class="btn-submit">Crear Cuenta</button>
        </form>
        <div class="login-link">
            <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
            <p><a href="/" class="btn-back">Volver al inicio</a></p>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>