<%- include('./partials/header') %>

<main style="padding: 40px 10%">

    <a href="/"style="background: #4a4e54; color: white; border: none; padding: 12px 24px; border-radius: 20px; cursor: pointer; margin-bottom: 10px; font-size: 1.0rem; text-decoration: none;">Volver al inicio</a>
    <h2 style="margin: 30px 0;">Productos en tu Carrito</h2>

    <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">

        <% for (const product of products) { %>
            <article style="width: 280px; background-color: #ffffff; border: 1px solid #eaeaea; border-radius: 8px; overflow: hidden; box-shadow: 0px 4px 10px rgba(0,0,0,0.05); display: flex; flex-direction: column;">
                
                <img src="<%= product.image %>" alt="<%= product.title %>" style="width: 100%; height: 200px; object-fit: cover;">

                <div style="padding: 15px; text-align: center; flex-grow: 1;">
                    <h3 style="font-size: 1.1rem; margin: 0 0 5px 0;"><%= product.title %></h3>
                    <p style="font-size: 1.2rem; font-weight: bold; color: #e44d26; margin: 5px 0;">$<%= product.price %></p>
                    <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;"><%= product.description %></p>
                    
                    <button style="background: #4a4e54; color: white; border: none; padding: 6px 12px; border-radius: 20px; cursor: pointer; margin-bottom: 10px; font-size: 0.8rem;">Quitar</button>

                    <div style="display: flex; justify-content: center; align-items: center; border: 1px solid #ccc; border-radius: 20px; padding: 2px 8px; max-width: 100px; margin: 0 auto;">
                        <button style="background: none; border: none; cursor: pointer; font-weight: bold;"> - </button>
                        <span style="margin: 0 10px;">1</span> 
                        <button style="background: none; border: none; cursor: pointer; font-weight: bold;"> + </button>
                    </div>
                </div>
            </article>
        <% } %>

    </div>

    <div style="text-align: right; margin-top: 40px;">
        <button style="background-color: #4a4e54; color: white; padding: 15px 40px; border: none; border-radius: 25px; font-size: 16px; cursor: pointer;">Ir a Pagar</button>
    </div>
</main>
<%- include('./partials/footer') %>