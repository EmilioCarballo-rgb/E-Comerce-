<%- include('../partials/header') %>
    <main class="cart-main">
        <a href="/" class="btn-volver">Volver al inicio</a>
        <h2 class="cart-title">Productos en tu Carrito</h2>

        <div class="cart-container">
            <% if (cart.length> 0) { %>
                <% for (const item of cart) { %>
                    <article class="item-carrito">
                        <img src="<%= item.image %>" alt="<%= item.title %>" class="cart-img">

                        <div class="cart-info">
                            <h3>
                                <%= item.title %>
                            </h3>
                        </div>

                        <div class="cart-controls">
                            <a href="/cart/remove/<%= item.id %>">
                                <button type="button" class="btn-quitar">Quitar</button>
                            </a>

                            <div class="cart-quantity-box">
                                <a href="/cart/decrease/<%= item.id %>">
                                    <button type="button" class="btn-menos"> - </button>
                                </a>

                                <span class="cantidad">
                                    <%= item.quantity %>
                                </span>

                                <!-- Aumentar cantidad -->
                                <a href="/cart/increase/<%= item.id %>">
                                    <button type="button" class="btn-mas"> + </button>
                                </a>
                            </div>

                            <p class="precio-subtotal">$<%= item.subtotal %>
                            </p>
                        </div>
                    </article>
                    <% } %>
                        <% } else { %>
                            <div style="text-align: center; width: 100%;">
                                <p>Tu carrito está vacío actualmente.</p>
                                <a href="/" class="btn-volver">Ir a ver productos</a>
                            </div>
                            <% } %>
        </div>

        <% if (cart.length> 0) { %>
            <div class="cart-summary">
                <h3>Total a Pagar: <span id="gran-total">$<%= total %></span></h3>

                <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 10px;">
                    <a href="/cart/checkout"><button class="btn-pagar">Ir a Pagar</button></a>
                    <a href="/cart/empty">
                        <button type="button" class="btn-vaciar">Vaciar carrito</button>
                    </a>
                </div>
            </div>
            <% } %>
    </main>

    <%- include('../partials/footer') %>