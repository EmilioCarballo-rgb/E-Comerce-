
<main style="padding: 40px 10%; min-height: 70vh; font-family: sans-serif;">
    
    <div style="text-align: center; margin-bottom: 40px;">
        <h1 style="text-transform: capitalize; color: #333; font-size: 2.5rem; border-bottom: 2px solid #2d5a27; display: inline-block; padding-bottom: 10px;">
            Categoría: <%= categoryName %>
        </h1>
    </div>

    <% if (products.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 30px;">
            <% products.forEach(producto => { %>
                <%- include('../partials/productCard', { product: producto }) %>
            <% }) %>
        </div>
        
    <% } else { %>
        <div style="text-align: center; padding: 60px 20px; background-color: #f9f9f9; border-radius: 12px; border: 1px dashed #ccc;">
            <h2 style="color: #555; margin-bottom: 15px;">¡Uy! Todavía no hay productos acá.</h2>
            <p style="color: #777; font-size: 1.2rem; margin-bottom: 30px;">
                Estamos preparando nuevos ingresos para la categoría <strong><%= categoryName %></strong>. ¡Volvé pronto!
            </p>
            <a href="/" style="background-color: #4a4e54; color: white; padding: 12px 30px; text-decoration: none; border-radius: 6px; font-weight: bold;">
                Ver todos los productos
            </a>
        </div>
    <% } %>

</main>

